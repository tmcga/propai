# ── PropAI Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── App ───────────────────────────────────────────────────────────────────
ENV=development                   # development | production
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Authentication (optional — leave empty to disable) ────────────────────
PROPAI_API_KEYS=                  # Comma-separated API keys (e.g. key1,key2)

# ── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=30            # Max requests per window
RATE_LIMIT_WINDOW=60              # Window in seconds

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://propai:propai@localhost:5432/propai

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AI / LLM ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...      # Get at console.anthropic.com
# OPENAI_API_KEY=sk-...           # Optional: OpenAI fallback

# ── Data APIs (all free tiers) ─────────────────────────────────────────────
CENSUS_API_KEY=                   # api.census.gov/data/key_signup.html
FRED_API_KEY=                     # fred.stlouisfed.org/docs/api/api_key.html
WALKSCORE_API_KEY=                # www.walkscore.com/professional/api.php
# HUD API does not require a key for most endpoints
# Zillow Research data is bulk CSV — no key needed

# ── File Storage ─────────────────────────────────────────────────────────
STORAGE_BACKEND=local                 # local | s3
STORAGE_LOCAL_PATH=./uploads          # path for local storage

# ── Frontend ──────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
